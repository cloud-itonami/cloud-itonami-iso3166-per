#:culture{:id "per.dish.ceviche", :name "Ceviche", :country "PER", :kind :dish, :summary "Considered the national dish of Peru and recognized by UNESCO as an expression of Peruvian traditional cuisine and Intangible Cultural Heritage of Humanity; the modern version originated during colonial times in present-day Peru.", :url "https://en.wikipedia.org/wiki/Ceviche", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.dish.lomo-saltado", :name "Lomo Saltado", :country "PER", :kind :dish, :summary "Traditional Peruvian dish, a stir-fry that typically combines marinated strips of sirloin with onions, tomatoes and French fries.", :url "https://en.wikipedia.org/wiki/Lomo_saltado", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.dish.cuy", :name "Cuy", :country "PER", :kind :dish, :summary "Guinea pig, part of Peruvian cuisine, often served whole or used as filling for foods such as tacos and ravioli.", :url "https://en.wikipedia.org/wiki/Peruvian_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.beverage.pisco", :name "Pisco", :country "PER", :kind :beverage, :summary "Colorless or yellowish-to-amber-colored spirit produced in winemaking regions of Peru and Chile; historians generally believe pisco originated in Peru, though both countries claim it as their national drink.", :url "https://en.wikipedia.org/wiki/Pisco", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.product.alpaca-fiber", :name "Alpaca fiber", :country "PER", :kind :product, :summary "Fiber from alpacas, which were domesticated from vicunas over 5,000 years ago by ancient tribes of the Andean highlands of Ecuador, Peru, Chile, Bolivia and northwest Argentina.", :url "https://en.wikipedia.org/wiki/Alpaca_fiber", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.craft.retablo", :name "Retablo", :country "PER", :kind :craft, :summary "Peruvian portable altarpiece art form; underwent a 1940s resurgence in Peru led by artist Joaquin Lopez Antay with support from the Peruvian indigenista movement, becoming a family heirloom symbolizing protection, fertility and healing.", :url "https://en.wikipedia.org/wiki/Retablo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.festival.inti-raymi", :name "Inti Raymi", :country "PER", :kind :festival, :summary "Celebrated on June 24, the most important festival of the Inca Empire, historically held in Haukaypata, the main square of Cusco, Peru.", :url "https://en.wikipedia.org/wiki/Inti_Raymi", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "per.heritage.machu-picchu", :name "Machu Picchu", :country "PER", :kind :heritage, :summary "Inca citadel in Peru designated a UNESCO World Heritage Site in 1983, described by UNESCO as 'a masterpiece of art, urbanism, architecture and engineering'.", :url "https://en.wikipedia.org/wiki/Machu_Picchu", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
